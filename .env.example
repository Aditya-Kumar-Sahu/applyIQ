# App
APP_NAME=ApplyIQ API
ENVIRONMENT=development
RELEASE_VERSION=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_DIR=logs
LOG_FILE_NAME=backend.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5
CORS_ORIGINS=["http://localhost:3000"]

# Database
POSTGRES_DB=applyiq
POSTGRES_USER=applyiq
POSTGRES_PASSWORD=applyiq-dev-password
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
PGVECTOR_ENABLED=true

# Redis and Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Auth
# JWT signing secret used for access and refresh tokens. Generate a long random secret and keep it server-side only.
JWT_SECRET_KEY=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_REGISTER_RATE_LIMIT=5
AUTH_LOGIN_RATE_LIMIT=10
AUTH_RATE_WINDOW_SECONDS=60

# Encryption
# Fernet key used to encrypt vault credentials and resume blobs. Generate with `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`.
FERNET_SECRET_KEY=replace-with-a-fernet-key
# Server-side pepper mixed into key derivation. Generate a separate random secret and never expose it to clients.
ENCRYPTION_PEPPER=replace-with-a-random-pepper

# AI Providers
# Google Gemini API key used by the current LLM and health-check paths.
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Job Discovery APIs
# Apify token used for LinkedIn discovery and other actor-based scrapers.
APIFY_API_TOKEN=
# SerpAPI key used for Google Jobs search results.
SERPAPI_API_KEY=

# Gmail OAuth
# Google OAuth client credentials for Gmail polling integration.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Storage
# Cloudflare R2 credentials for screenshot and artifact uploads.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=applyiq-screenshots
R2_PUBLIC_URL=

# Notifications
# Resend API key used for notification email delivery.
RESEND_API_KEY=
FROM_EMAIL=noreply@applyiq.app

# Sentry
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.0
VITE_RELEASE_VERSION=dev

# Feature Flags
ENABLE_AUTO_APPLY=true
AUTO_APPLY_DEMO_MODE=true
PLAYWRIGHT_ENABLED=false
AUTO_APPLY_USE_BROWSER=false
AUTO_APPLY_HEADLESS=true
AUTO_APPLY_ARTIFACT_ROOT=artifacts
MAX_AUTO_APPLY_PER_RUN=20

# Frontend
VITE_API_URL=http://localhost:8001
