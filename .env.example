# App
APP_NAME=ApplyIQ API
ENVIRONMENT=development
RELEASE_VERSION=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_TO_FILE=true
LOG_DIR=logs
LOG_FILE_NAME=backend.log
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=5
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://applyiq:password@db:5432/applyiq
PGVECTOR_ENABLED=true

# Redis and Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption
FERNET_SECRET_KEY=wWKJg6WVKwwhFVWG2yt30YIOCwVDDDeWGPAHDLcGRID=
ENCRYPTION_PEPPER=change-me-in-production

# AI Providers
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Job Discovery APIs
APIFY_API_TOKEN=
SERPAPI_API_KEY=

# Gmail OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=applyiq-screenshots
R2_PUBLIC_URL=

# Notifications
RESEND_API_KEY=
FROM_EMAIL=noreply@applyiq.app

# Sentry
SENTRY_DSN_BACKEND=
SENTRY_DSN_FRONTEND=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.0
VITE_RELEASE_VERSION=dev

# Feature Flags
ENABLE_AUTO_APPLY=true
MAX_AUTO_APPLY_PER_RUN=20

# Frontend
VITE_API_URL=http://localhost:8001
